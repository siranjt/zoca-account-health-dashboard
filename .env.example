# ============================================================================
# Zoca Account Health Dashboard — environment variables
# Copy this file to .env.local for local dev. In production, set these in
# Vercel → Project → Settings → Environment Variables.
# NEVER commit real values. .env* files are gitignored.
# ============================================================================

# --- Alfred reasoning (CAVE//OS chat) ---------------------------------------
# Required for the "Ask Alfred" chat (/api/ask) to reason. Without it the
# chat still renders but replies that no key is configured.
ANTHROPIC_API_KEY=
# Optional — model Alfred reasons with (defaults to claude-sonnet-4-6).
ANTHROPIC_ASK_MODEL=claude-sonnet-4-6

# --- Data source ------------------------------------------------------------
# When DATA_SOURCE=mock (default if unset), the app serves realistic sample
# data and needs no Metabase access — perfect for previewing / first deploy.
# Set DATA_SOURCE=metabase once the values below are filled in.
DATA_SOURCE=mock

# --- Metabase (server-side only; never exposed to the browser) --------------
# Base URL of your Metabase instance, e.g. https://metabase.zoca.com
METABASE_BASE_URL=
# Metabase API key (sent as the X-API-KEY header)
METABASE_API_KEY=
# Metabase database id that the SQL questions run against (integer)
METABASE_DATABASE_ID=

# Saved Metabase Question (card) IDs that power each column. Fill these in with
# the card IDs behind the Retool Customer Dashboard tabs. See src/lib/metabase.ts.
METABASE_CARD_ACCOUNTS=
METABASE_CARD_LEADS=
METABASE_CARD_REVIEWS=
METABASE_CARD_PHOTOS=
METABASE_CARD_RANKINGS=
METABASE_CARD_IMPRESSIONS=
METABASE_CARD_GBP_METRICS=
METABASE_CARD_HEALTH=
METABASE_CARD_PRODUCTS=

# --- Reporting window (days) used for "leads received", "reviews", clicks ----
METRICS_WINDOW_DAYS=30

# --- Optional password gate (simple protection for the whole app) -----------
# If set, visitors must enter this password. Leave blank to rely on Vercel's
# built-in Deployment Protection instead (recommended for customer data).
DASHBOARD_PASSWORD=
